{
  "manifest_version": 3,
  "name": "EZGPhotos",
  "version": "0.1.0",
  "description": "Overlay keyboard album management controls on top of Google Photos.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://photos.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://photos.google.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}

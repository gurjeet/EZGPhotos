+    subtree: true,
+    attributes: true,
+    attributeFilter: ['aria-selected', 'aria-checked', 'src', 'alt', 'data-ezg-member', 'data-ezg-photo-id'],
+  });
+}
+
+if (document.readyState === 'loading') {
+  document.addEventListener('DOMContentLoaded', boot, { once: true });
